# Copie este arquivo para .env e preencha com credenciais reais.
# O .env NÃO é versionado (ver .gitignore).

# Ponto de entrada do perfil no Professor Online.
# Padrão: Professor(a) Ensino Fundamental (Brusque/SC).
PO_ENTRY_URL=https://professor.brusque.sc.gov.br/pol/index.php?op=RUVGc2pBSkljNVNyZw==

# Credenciais de acesso (necessárias apenas para o spike de login, não para a recon).
# O login do Professor Online é feito com CPF (somente números) + senha.
PO_CPF=
PO_PASSWORD=

# Modo do navegador durante o desenvolvimento.
# headed = janela visível (recomendado para depurar); headless = sem janela.
HEADLESS=false
